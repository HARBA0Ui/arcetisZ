DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority"
JWT_SECRET="replace-with-a-long-random-jwt-secret"
AUTH_SECRET="replace-with-a-long-random-nextauth-secret"
APP_ENCRYPTION_SECRET="replace-with-a-long-random-encryption-secret"
NEXTAUTH_URL="http://localhost:3000/api/next-auth"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
ADMIN_EMAILS="admin@arcetis.com"
WEBHOOK_SHARED_SECRET="replace-with-a-long-random-webhook-secret"
# Find the Cloudinary cloud name in the dashboard or API environment variable.
# It is not the same thing as the API key label / key name.
CLOUDINARY_CLOUD_NAME="replace-with-your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="replace-with-your-cloudinary-api-key"
CLOUDINARY_API_SECRET="replace-with-your-cloudinary-api-secret"
